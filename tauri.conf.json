{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex 提示音管理器",
  "version": "1.1.0",
  "identifier": "com.codexsound.manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Codex 提示音管理器",
        "width": 960,
        "height": 840,
        "minWidth": 820,
        "minHeight": 650,
        "center": true,
        "resizable": true,
        "maximized": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; font-src 'self' asset:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "shortDescription": "为 Codex 任务完成播放自定义提示音",
    "longDescription": "自动发现 Codex 全局配置，设置任务完成提示音、播放次数和自定义音频。",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
